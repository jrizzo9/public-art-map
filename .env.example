# Canonical site URL (no trailing slash). On Vercel, set explicitly to your subdomain.
NEXT_PUBLIC_SITE_URL=https://map.creativewaco.org

# Published Google Sheet CSV URL (Share → Publish to web → CSV).
SHEET_CSV_URL=

# Mapbox public token (client-side GL JS).
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: Mapbox Studio style URL (defaults to Mapbox Streets).
# NEXT_PUBLIC_MAPBOX_STYLE_URL=mapbox://styles/your-org/your-style

# ISR / fetch revalidation for sheet data (seconds). Use 0 for no fetch cache (always pull latest CSV).
REVALIDATE_SECONDS=300

# If true, attempt to geocode from address when lat/lng are missing (requires Mapbox token).
# GEOCODE_MISSING_COORDS=true

# Optional: image_id column → full image URL for map/popup/detail (replace {id}).
# NEXT_PUBLIC_ARTWORK_IMAGE_URL_TEMPLATE=https://cdn.example.com/images/{id}.webp

# Comma-separated origins allowed to iframe /embed/* (Webflow). Defaults to creativewaco.org + www.
# EMBED_ALLOWED_ORIGINS=https://creativewaco.org,https://www.creativewaco.org

# --- Optional: Cloudinary migration helpers (scripts only; do not expose in NEXT_PUBLIC_*) ---
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=public-art-map
